#!/usr/bin/env bash
# sbctl — SignalBridge control script.
#
# Wraps uvicorn so the operator doesn't have to retype the full command.
# All state lives under the SignalBridge project root:
#
#   runtime/signalbridge.pid   live PID of the running uvicorn (if any)
#   logs/server.out            captured stdout/stderr of the server
#   logs/signalbridge.log      application logger output (rotated)
#
# Commands:
#   Lifecycle:    start | stop | restart | status
#   Observe:      logs | tail | health | audit | env
#   Execution:    mode | arm | disarm | flatten
#   Testing:      test | smoke
#   Maintenance:  backup
#
# Defaults to host 127.0.0.1 and port 8000. APP_HOST/APP_PORT in .env
# override; pass --host / --port to override the env. Tailscale Funnel
# (and any other public proxy) should forward to 127.0.0.1:8000.
#
# Admin-API commands (mode/arm/disarm/flatten/smoke) read ADMIN_USERNAME
# and ADMIN_PASSWORD from .env and authenticate via HTTP Basic. If only
# ADMIN_PASSWORD_HASH is set, those commands refuse — the dashboard
# remains the way to drive them.
set -euo pipefail

# Resolve PROJECT_ROOT from the script's location so `sbctl` works the
# same whether invoked directly or via a ~/.local/bin symlink.
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

RUNTIME_DIR="$PROJECT_ROOT/runtime"
LOGS_DIR="$PROJECT_ROOT/logs"
PID_FILE="$RUNTIME_DIR/signalbridge.pid"
SERVER_OUT="$LOGS_DIR/server.out"
APP_LOG="$LOGS_DIR/signalbridge.log"

DEFAULT_HOST="127.0.0.1"
DEFAULT_PORT="8000"

# ----- helpers -----

err() { echo "sbctl: $*" >&2; }
info() { echo "[sbctl] $*"; }

ensure_dirs() {
  mkdir -p "$RUNTIME_DIR" "$LOGS_DIR"
}

load_env_host_port() {
  # Source .env so APP_HOST / APP_PORT propagate, but only export those
  # two — sourcing the whole file blindly could clobber values the
  # operator is intentionally controlling via shell env.
  HOST_VALUE="$DEFAULT_HOST"
  PORT_VALUE="$DEFAULT_PORT"
  if [ -f "$PROJECT_ROOT/.env" ]; then
    while IFS= read -r line; do
      case "$line" in
        APP_HOST=*) HOST_VALUE="${line#APP_HOST=}" ;;
        APP_PORT=*) PORT_VALUE="${line#APP_PORT=}" ;;
      esac
    done < "$PROJECT_ROOT/.env"
  fi
  # Strip surrounding quotes if present.
  HOST_VALUE="${HOST_VALUE%\"}"; HOST_VALUE="${HOST_VALUE#\"}"
  HOST_VALUE="${HOST_VALUE%\'}"; HOST_VALUE="${HOST_VALUE#\'}"
  PORT_VALUE="${PORT_VALUE%\"}"; PORT_VALUE="${PORT_VALUE#\"}"
  PORT_VALUE="${PORT_VALUE%\'}"; PORT_VALUE="${PORT_VALUE#\'}"
}

load_env_admin_auth() {
  # Reads ADMIN_USERNAME / ADMIN_PASSWORD / ADMIN_PASSWORD_HASH from
  # .env into shell vars. Used by anything that POSTs to the admin
  # API. Refuses if only the hash is set, since we can't reconstruct
  # the plaintext for Basic auth.
  ADMIN_USERNAME_VALUE="admin"
  ADMIN_PASSWORD_VALUE=""
  ADMIN_PASSWORD_HASH_VALUE=""
  if [ -f "$PROJECT_ROOT/.env" ]; then
    while IFS= read -r line; do
      case "$line" in
        ADMIN_USERNAME=*) ADMIN_USERNAME_VALUE="${line#ADMIN_USERNAME=}" ;;
        ADMIN_PASSWORD=*) ADMIN_PASSWORD_VALUE="${line#ADMIN_PASSWORD=}" ;;
        ADMIN_PASSWORD_HASH=*) ADMIN_PASSWORD_HASH_VALUE="${line#ADMIN_PASSWORD_HASH=}" ;;
      esac
    done < "$PROJECT_ROOT/.env"
  fi
  ADMIN_USERNAME_VALUE="${ADMIN_USERNAME_VALUE%\"}"; ADMIN_USERNAME_VALUE="${ADMIN_USERNAME_VALUE#\"}"
  ADMIN_USERNAME_VALUE="${ADMIN_USERNAME_VALUE%\'}"; ADMIN_USERNAME_VALUE="${ADMIN_USERNAME_VALUE#\'}"
  ADMIN_PASSWORD_VALUE="${ADMIN_PASSWORD_VALUE%\"}"; ADMIN_PASSWORD_VALUE="${ADMIN_PASSWORD_VALUE#\"}"
  ADMIN_PASSWORD_VALUE="${ADMIN_PASSWORD_VALUE%\'}"; ADMIN_PASSWORD_VALUE="${ADMIN_PASSWORD_VALUE#\'}"
  ADMIN_PASSWORD_HASH_VALUE="${ADMIN_PASSWORD_HASH_VALUE%\"}"; ADMIN_PASSWORD_HASH_VALUE="${ADMIN_PASSWORD_HASH_VALUE#\"}"
  ADMIN_PASSWORD_HASH_VALUE="${ADMIN_PASSWORD_HASH_VALUE%\'}"; ADMIN_PASSWORD_HASH_VALUE="${ADMIN_PASSWORD_HASH_VALUE#\'}"
  if [ -z "$ADMIN_PASSWORD_VALUE" ] && [ -n "$ADMIN_PASSWORD_HASH_VALUE" ]; then
    err "ADMIN_PASSWORD not found in .env and hash is set. Either set ADMIN_PASSWORD or use the dashboard for this operation."
    return 1
  fi
  if [ -z "$ADMIN_PASSWORD_VALUE" ]; then
    err "ADMIN_PASSWORD not set in .env — cannot authenticate to admin API"
    return 1
  fi
}

load_env_webhook_secret() {
  WEBHOOK_SECRET_VALUE=""
  if [ -f "$PROJECT_ROOT/.env" ]; then
    while IFS= read -r line; do
      case "$line" in
        TRADINGVIEW_WEBHOOK_SECRET=*)
          WEBHOOK_SECRET_VALUE="${line#TRADINGVIEW_WEBHOOK_SECRET=}"
          ;;
      esac
    done < "$PROJECT_ROOT/.env"
  fi
  WEBHOOK_SECRET_VALUE="${WEBHOOK_SECRET_VALUE%\"}"; WEBHOOK_SECRET_VALUE="${WEBHOOK_SECRET_VALUE#\"}"
  WEBHOOK_SECRET_VALUE="${WEBHOOK_SECRET_VALUE%\'}"; WEBHOOK_SECRET_VALUE="${WEBHOOK_SECRET_VALUE#\'}"
  if [ -z "$WEBHOOK_SECRET_VALUE" ]; then
    err "TRADINGVIEW_WEBHOOK_SECRET not set in .env"
    return 1
  fi
  case "$WEBHOOK_SECRET_VALUE" in
    REPLACE_ME*)
      err "TRADINGVIEW_WEBHOOK_SECRET still has its placeholder value — set a real secret first"
      return 1
      ;;
  esac
}

read_pid() {
  if [ -f "$PID_FILE" ]; then
    cat "$PID_FILE" 2>/dev/null || true
  fi
}

pid_alive() {
  local pid="$1"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

port_listener_pid() {
  # Best-effort: returns the PID listening on $1 (PORT_VALUE), if any.
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -ti ":$port" 2>/dev/null | head -n 1 || true
  elif command -v ss >/dev/null 2>&1; then
    ss -ltnpH "sport = :$port" 2>/dev/null \
      | grep -oE 'pid=[0-9]+' | head -n 1 | cut -d= -f2 || true
  fi
}

# ----- commands -----

cmd_start() {
  ensure_dirs
  load_env_host_port

  local existing_pid
  existing_pid="$(read_pid)"
  if pid_alive "$existing_pid"; then
    info "already running (pid $existing_pid) on $HOST_VALUE:$PORT_VALUE"
    return 0
  fi

  # Stale pid file — clear it before starting fresh.
  if [ -f "$PID_FILE" ]; then
    rm -f "$PID_FILE"
  fi

  local listener
  listener="$(port_listener_pid "$PORT_VALUE")"
  if [ -n "$listener" ]; then
    err "port $PORT_VALUE is already in use by pid $listener"
    err "stop that process (or run 'sbctl stop') before starting"
    return 1
  fi

  cd "$PROJECT_ROOT"

  if [ -f ".venv/bin/activate" ]; then
    # shellcheck disable=SC1091
    source .venv/bin/activate
  fi

  info "starting uvicorn on $HOST_VALUE:$PORT_VALUE"
  # nohup + setsid keeps the server alive after the controlling shell
  # exits. stdout/stderr land in $SERVER_OUT; the application logger
  # writes its own rotated file at $APP_LOG.
  nohup setsid python -m uvicorn app.main:app \
    --host "$HOST_VALUE" --port "$PORT_VALUE" \
    >>"$SERVER_OUT" 2>&1 < /dev/null &
  local new_pid=$!
  echo "$new_pid" > "$PID_FILE"
  # Give uvicorn a beat to bind the port so the message is accurate.
  sleep 0.5
  if pid_alive "$new_pid"; then
    info "started (pid $new_pid); logs: $SERVER_OUT"
  else
    err "process exited immediately — check $SERVER_OUT"
    rm -f "$PID_FILE"
    return 1
  fi
}

cmd_stop() {
  load_env_host_port
  local pid
  pid="$(read_pid)"

  if ! pid_alive "$pid"; then
    # PID file missing or stale — fall back to whatever owns the port.
    pid="$(port_listener_pid "$PORT_VALUE")"
  fi

  if [ -z "$pid" ]; then
    info "nothing to stop"
    [ -f "$PID_FILE" ] && rm -f "$PID_FILE"
    return 0
  fi

  info "stopping pid $pid"
  # Kill the whole process group so child workers go with the parent.
  if kill -TERM "-$pid" 2>/dev/null; then
    :
  else
    kill -TERM "$pid" 2>/dev/null || true
  fi

  local i=0
  while pid_alive "$pid" && [ "$i" -lt 20 ]; do
    sleep 0.25
    i=$((i + 1))
  done
  if pid_alive "$pid"; then
    err "process did not exit after SIGTERM; sending SIGKILL"
    kill -KILL "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
  fi
  [ -f "$PID_FILE" ] && rm -f "$PID_FILE"
  info "stopped"
}

cmd_restart() {
  cmd_stop || true
  cmd_start
}

cmd_status() {
  ensure_dirs
  load_env_host_port
  local pid running
  pid="$(read_pid)"
  if pid_alive "$pid"; then
    running="yes"
  else
    running="no"
    pid=""
  fi

  echo "project    : $PROJECT_ROOT"
  echo "pid file   : $PID_FILE"
  echo "running    : $running"
  [ -n "$pid" ] && echo "pid        : $pid"
  echo "bind       : $HOST_VALUE:$PORT_VALUE"

  local listener
  listener="$(port_listener_pid "$PORT_VALUE")"
  if [ -n "$listener" ]; then
    echo "port owner : pid $listener"
  else
    echo "port owner : (none)"
  fi

  if command -v curl >/dev/null 2>&1; then
    local health
    health="$(curl -sf --max-time 2 \
      "http://$HOST_VALUE:$PORT_VALUE/health" 2>/dev/null || true)"
    if [ -n "$health" ]; then
      echo "health     : $health"
    else
      echo "health     : (unreachable)"
    fi
  else
    echo "health     : (curl not installed)"
  fi
}

cmd_logs() {
  ensure_dirs
  local files=()
  [ -f "$SERVER_OUT" ] && files+=("$SERVER_OUT")
  [ -f "$APP_LOG" ] && files+=("$APP_LOG")
  if [ "${#files[@]}" -eq 0 ]; then
    info "no logs yet; expected $APP_LOG (and $SERVER_OUT after start)"
    return 0
  fi
  info "tailing: ${files[*]} (Ctrl+C to stop)"
  # `tail -F` keeps following across log rotation; safe for both files.
  exec tail -n 100 -F "${files[@]}"
}

cmd_health() {
  load_env_host_port
  if ! command -v curl >/dev/null 2>&1; then
    err "curl is not installed"
    return 1
  fi
  curl -sf --max-time 5 "http://$HOST_VALUE:$PORT_VALUE/health"
  local rc=$?
  echo
  return $rc
}

cmd_audit() {
  # Print a non-secret safety snapshot suitable for visual review.
  # Reads the SQLite settings store directly via a small Python helper
  # so it works whether or not the server is running. No tokens, no
  # passwords, no webhook secret values — only set/unset flags and
  # masked previews.
  cd "$PROJECT_ROOT"
  if [ -f ".venv/bin/activate" ]; then
    # shellcheck disable=SC1091
    source .venv/bin/activate
  fi
  python - <<'PY'
import os
import sys

sys.path.insert(0, os.getcwd())

from app.config import get_settings  # noqa: E402
from app.settings_store import SettingsStore  # noqa: E402
from app.symbol_map import SymbolMap  # noqa: E402

s = get_settings()
store = SettingsStore(s.database_abs_path)
store.initialize_settings_from_env(s)
sm = SymbolMap(s.symbols_map_abs_path)
mappings = sm.all_mappings()

def yn(b):
    return "yes" if bool(b) else "no"

def mask(v):
    if not v:
        return "(unset)"
    text = str(v)
    if len(text) <= 4:
        return "configured"
    return f"set (…{text[-4:]})"

execution_mode = s.execution_mode
provider = s.resolved_provider
demo_armed = (
    provider == "topstep"
    and execution_mode == "demo"
    and bool(s.enable_topstep_order_execution)
    and (s.topstep_execution_confirm or "") == "DEMO_ONLY"
    and bool(s.resolved_account_id)
)
live_armed = (
    provider == "topstep"
    and execution_mode == "live"
    and bool(s.enable_topstep_order_execution)
    and (s.topstep_execution_confirm or "") == "LIVE_CONFIRMED"
    and bool(s.enable_live_trading)
    and (s.live_trading_confirm or "") == "I_UNDERSTAND_LIVE_ORDERS"
    and bool(s.live_trading_account_ack)
    and bool(s.resolved_account_id)
)

print("=== SignalBridge audit ===")
print(f"broker_provider          : {provider}")
print(f"execution_mode           : {execution_mode}")
print(f"kill_switch_enabled      : {yn(s.enable_kill_switch)}")
kill_path = s.database_abs_path.parent / 'kill_switch.active'
print(f"kill_switch_active       : {yn(kill_path.exists())}")
print(f"webhook secret configured: {yn(s.webhook_secret and s.webhook_secret != 'change_me_to_a_long_random_secret')}")
print(f"admin auth enabled       : {yn(s.admin_auth_enabled)}")
print(f"admin password storage   : {'hash' if s.admin_password_hash else 'plaintext-env-fallback'}")
print()
print("--- topstep ---")
print(f"topstep username         : {yn(bool(s.topstep_username))}")
print(f"topstep api key          : {mask(s.topstep_api_key)}")
print(f"topstep account id       : {s.topstep_account_id or '(unset)'}")
print(f"topstep selected account : {s.resolved_account_id or '(unset)'}")
print(f"topstep token cached     : {yn(bool(s.topstep_token))}")
print()
print("--- symbol map ---")
print(f"symbol map path          : {s.symbols_map_abs_path}")
print(f"symbol map entries       : {len(mappings)}")
for ticker, m in sorted(mappings.items()):
    paper = m.get('paper') or '—'
    topstep = m.get('topstep') or '—'
    tradovate = m.get('tradovate') or '—'
    print(f"  {ticker:<10} paper={paper} topstep={topstep} tradovate={tradovate}")
print()
print("--- demo execution ---")
print(f"ENABLE_TOPSTEP_ORDER_DRY_RUN   : {yn(s.enable_topstep_order_dry_run)}")
print(f"ENABLE_TOPSTEP_ORDER_EXECUTION : {yn(s.enable_topstep_order_execution)}")
print(f"TOPSTEP_EXECUTION_CONFIRM      : {s.topstep_execution_confirm}")
print(f"demo execution armed           : {yn(demo_armed)}")
print()
print("--- live execution ---")
print(f"ENABLE_LIVE_TRADING            : {yn(s.enable_live_trading)}")
print(f"LIVE_TRADING_CONFIRM           : {s.live_trading_confirm}")
print(f"LIVE_TRADING_ACCOUNT_ACK       : {yn(s.live_trading_account_ack)}")
print(f"LIVE_MAX_CONTRACTS_PER_TRADE   : {s.live_max_contracts_per_trade}")
print(f"MAX_CONTRACTS_PER_TRADE        : {s.max_contracts_per_trade}")
print(f"LIVE_ALLOWED_SYMBOLS           : {','.join(s.live_allowed_symbols) or '(none)'}")
print(f"LIVE_REQUIRE_KILL_SWITCH_OFF   : {yn(s.live_require_kill_switch_off)}")
print(f"live execution armed           : {yn(live_armed)}")
if live_armed:
    print()
    print("!!! WARNING: live execution is currently ARMED — orders WILL be submitted to the funded Topstep account.")
PY
}

cmd_tail() {
  # Tail ONLY the structured application log. ``sbctl logs`` already
  # follows both server.out and signalbridge.log; this one is useful
  # when server.out is noisy with uvicorn boot output and the operator
  # only cares about app events.
  ensure_dirs
  local n="${1:-50}"
  case "$n" in
    ''|*[!0-9]*)
      err "tail: line count must be a non-negative integer (got '$n')"
      return 2
      ;;
  esac
  if [ ! -f "$APP_LOG" ]; then
    info "no app log yet at $APP_LOG"
    return 0
  fi
  info "tailing $APP_LOG (Ctrl+C to stop)"
  exec tail -n "$n" -F "$APP_LOG"
}

# --- HTTP helpers used by execution-control commands ---

# Pretty-print JSON to stdout when jq is available, raw otherwise.
print_json() {
  if command -v jq >/dev/null 2>&1; then
    printf '%s\n' "$1" | jq . 2>/dev/null || printf '%s\n' "$1"
  else
    printf '%s\n' "$1"
  fi
}

# Extract a top-level string field from a JSON blob. Uses jq when
# available; falls back to a best-effort grep so the script still
# works on slim hosts. Returns empty string when not found.
json_field() {
  local body="$1" key="$2"
  if command -v jq >/dev/null 2>&1; then
    printf '%s' "$body" | jq -r --arg k "$key" '.[$k] // empty' 2>/dev/null
    return
  fi
  printf '%s' "$body" \
    | grep -oE "\"$key\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" \
    | head -n 1 \
    | sed -E "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\".*/\1/"
}

# Extract a top-level boolean field from a JSON blob.
json_bool() {
  local body="$1" key="$2"
  if command -v jq >/dev/null 2>&1; then
    printf '%s' "$body" | jq -r --arg k "$key" '.[$k] // empty' 2>/dev/null
    return
  fi
  if printf '%s' "$body" | grep -qE "\"$key\"[[:space:]]*:[[:space:]]*true"; then
    echo true
  elif printf '%s' "$body" | grep -qE "\"$key\"[[:space:]]*:[[:space:]]*false"; then
    echo false
  fi
}

cmd_mode() {
  local state="${1:-}"
  case "$state" in
    off|test|armed) ;;
    "")
      err "mode: requires <off|test|armed>"
      return 2
      ;;
    *)
      err "mode: unknown state '$state' (expected off|test|armed)"
      return 2
      ;;
  esac
  if ! command -v curl >/dev/null 2>&1; then
    err "curl is not installed"
    return 1
  fi
  load_env_host_port
  load_env_admin_auth
  local url="http://$HOST_VALUE:$PORT_VALUE/api/execution/$state"
  local resp http_code body
  resp="$(curl -sS -u "$ADMIN_USERNAME_VALUE:$ADMIN_PASSWORD_VALUE" \
    -X POST -H "Content-Type: application/json" \
    -w $'\n%{http_code}' --max-time 10 "$url")" || {
      err "request to $url failed"
      return 1
    }
  http_code="${resp##*$'\n'}"
  body="${resp%$'\n'*}"
  print_json "$body"
  if [ "$http_code" != "200" ]; then
    err "HTTP $http_code"
    return 1
  fi
  info "execution_mode now: $state"
  if [ "$state" = "armed" ]; then
    local account
    account="$(json_field "$body" "selected_account_id")"
    [ -z "$account" ] && account="the selected account"
    echo "  ⚠️  WARNING: execution is now ARMED. Live orders will submit to Topstep account $account." >&2
  fi
}

cmd_arm() { cmd_mode armed; }
cmd_disarm() { cmd_mode off; }

cmd_test() {
  # Fire a synthetic webhook through /webhooks/tradingview using the
  # operator's real shared secret. Useful for smoke-testing the armed
  # path end-to-end without manual TradingView setup. The order_id is
  # always unique so retries don't trip the dedup guard.
  local action="${1:-}"
  case "$action" in
    buy|sell) ;;
    "")
      err "test: requires <buy|sell> [symbol] [contracts]"
      return 2
      ;;
    *)
      err "test: unknown action '$action' (expected buy|sell)"
      return 2
      ;;
  esac
  local symbol="${2:-MES1!}"
  local contracts="${3:-1}"
  case "$contracts" in
    ''|*[!0-9]*)
      err "test: contracts must be a positive integer (got '$contracts')"
      return 2
      ;;
  esac
  if ! command -v curl >/dev/null 2>&1; then
    err "curl is not installed"
    return 1
  fi
  load_env_host_port
  load_env_webhook_secret
  local order_id="sbctl-test-${action}-$(date +%s)"
  local url="http://$HOST_VALUE:$PORT_VALUE/webhooks/tradingview"
  local body
  body=$(printf '{"secret":"%s","symbol":"%s","action":"%s","contracts":%s,"order_id":"%s"}' \
    "$WEBHOOK_SECRET_VALUE" "$symbol" "$action" "$contracts" "$order_id")
  info "firing $action $symbol x$contracts (order_id=$order_id)"
  local resp http_code resp_body
  resp="$(curl -sS -X POST -H "Content-Type: application/json" \
    --data "$body" -w $'\n%{http_code}' --max-time 15 "$url")" || {
      err "request to $url failed"
      return 1
    }
  http_code="${resp##*$'\n'}"
  resp_body="${resp%$'\n'*}"
  print_json "$resp_body"
  # Export for smoke summary.
  TEST_LAST_ORDER_ID="$order_id"
  TEST_LAST_STATUS="$http_code"
  TEST_LAST_ACCEPTED="$(json_bool "$resp_body" "accepted")"
  [ -z "$TEST_LAST_ACCEPTED" ] && TEST_LAST_ACCEPTED="unknown"
  if [ "$TEST_LAST_ACCEPTED" = "false" ]; then
    return 1
  fi
  if [ "$http_code" != "200" ]; then
    err "HTTP $http_code"
    return 1
  fi
}

cmd_smoke() {
  # Round-trip smoke test: buy + sell-to-flatten. Requires armed mode
  # since the whole point is exercising the live path. Designed to be
  # the operator equivalent of the dashboard's old "armed test order"
  # button — a single command that proves submit + close both work.
  local symbol="${1:-MES1!}"
  local contracts="${2:-1}"
  case "$contracts" in
    ''|*[!0-9]*)
      err "smoke: contracts must be a positive integer (got '$contracts')"
      return 2
      ;;
  esac
  if ! command -v curl >/dev/null 2>&1; then
    err "curl is not installed"
    return 1
  fi
  load_env_host_port
  load_env_admin_auth
  local sys_url="http://$HOST_VALUE:$PORT_VALUE/api/system"
  local sys_body
  sys_body="$(curl -sS -u "$ADMIN_USERNAME_VALUE:$ADMIN_PASSWORD_VALUE" \
    --max-time 5 "$sys_url")" || {
      err "smoke: failed to read $sys_url (is the server running?)"
      return 1
    }
  local current_mode
  current_mode="$(json_field "$sys_body" "execution_mode")"
  [ -z "$current_mode" ] && current_mode="unknown"
  if [ "$current_mode" != "armed" ]; then
    err "smoke: requires execution_mode=armed (currently $current_mode). Run 'sbctl arm' first."
    return 1
  fi
  local delay="${SBCTL_SMOKE_DELAY:-3}"
  local buy_id buy_status buy_accepted
  local sell_id sell_status sell_accepted
  info "firing BUY..."
  # Don't let a failed BUY abort the script — we still want to print
  # the summary so the operator sees both legs. The exit code is
  # computed at the end from the accepted flags.
  set +e
  cmd_test buy "$symbol" "$contracts"
  local buy_rc=$?
  set -e
  buy_id="$TEST_LAST_ORDER_ID"
  buy_status="$TEST_LAST_STATUS"
  buy_accepted="$TEST_LAST_ACCEPTED"
  sleep "$delay"
  info "firing SELL to flatten..."
  set +e
  cmd_test sell "$symbol" "$contracts"
  local sell_rc=$?
  set -e
  sell_id="$TEST_LAST_ORDER_ID"
  sell_status="$TEST_LAST_STATUS"
  sell_accepted="$TEST_LAST_ACCEPTED"
  echo
  echo "=== smoke summary ==="
  echo "buy  : order_id=$buy_id http=$buy_status accepted=$buy_accepted"
  echo "sell : order_id=$sell_id http=$sell_status accepted=$sell_accepted"
  if [ "$buy_rc" -ne 0 ] || [ "$sell_rc" -ne 0 ]; then
    return 1
  fi
}

cmd_flatten() {
  # Emergency flatten — closes every open Topstep position via the
  # broker adapter. The dashboard's red FLATTEN ALL button hits the
  # same endpoint. Confirms interactively unless -y is passed.
  local yes="no"
  if [ "${1:-}" = "-y" ]; then
    yes="yes"
    shift
  fi
  if ! command -v curl >/dev/null 2>&1; then
    err "curl is not installed"
    return 1
  fi
  load_env_host_port
  load_env_admin_auth
  if [ "$yes" != "yes" ]; then
    printf "Flatten ALL positions on the selected Topstep account? (y/N) "
    local reply=""
    read -r reply || true
    case "$reply" in
      y|Y|yes|YES) ;;
      *) info "aborted"; return 0 ;;
    esac
  fi
  local url="http://$HOST_VALUE:$PORT_VALUE/api/broker/flatten-all"
  local resp http_code body
  resp="$(curl -sS -u "$ADMIN_USERNAME_VALUE:$ADMIN_PASSWORD_VALUE" \
    -X POST -w $'\n%{http_code}' --max-time 30 "$url")" || {
      err "flatten request to $url failed"
      return 1
    }
  http_code="${resp##*$'\n'}"
  body="${resp%$'\n'*}"
  print_json "$body"
  if [ "$http_code" != "200" ]; then
    err "HTTP $http_code"
    return 1
  fi
}

cmd_backup() {
  # Copy the live SQLite database and .env to an off-host path so a
  # disk loss doesn't take settings + journal with it. The .env copy
  # gets 0600 because it contains the webhook secret and broker
  # creds. Old backups past the retention window are pruned by mtime.
  local hostname_val
  hostname_val="$(hostname)"
  local dest="${1:-}"
  if [ -z "$dest" ]; then
    if [ -d "/mnt/nas-configs/$hostname_val/signalbridge" ]; then
      dest="/mnt/nas-configs/$hostname_val/signalbridge"
    else
      dest="$HOME/signalbridge-backups"
    fi
  fi
  mkdir -p "$dest"
  local ts db_src env_src db_dst env_dst
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  db_src="$PROJECT_ROOT/data/signalbridge.db"
  env_src="$PROJECT_ROOT/.env"
  db_dst="$dest/signalbridge-$hostname_val-$ts.db"
  env_dst="$dest/env-$hostname_val-$ts.env"
  if [ ! -f "$db_src" ]; then
    err "database not found at $db_src"
    return 1
  fi
  if [ ! -f "$env_src" ]; then
    err ".env not found at $env_src"
    return 1
  fi
  cp -p "$db_src" "$db_dst"
  cp -p "$env_src" "$env_dst"
  chmod 600 "$env_dst"
  info "destination: $dest"
  info "db  : $db_dst ($(du -h "$db_dst" 2>/dev/null | awk '{print $1}'))"
  info "env : $env_dst ($(du -h "$env_dst" 2>/dev/null | awk '{print $1}'))"
  # Retention: keep the 30 most recent of each kind by mtime.
  local pruned=0 idx
  idx=0
  while IFS= read -r f; do
    idx=$((idx + 1))
    if [ "$idx" -gt 30 ]; then
      rm -f "$f" && pruned=$((pruned + 1))
    fi
  done < <(ls -1t "$dest"/signalbridge-"$hostname_val"-*.db 2>/dev/null || true)
  idx=0
  while IFS= read -r f; do
    idx=$((idx + 1))
    if [ "$idx" -gt 30 ]; then
      rm -f "$f" && pruned=$((pruned + 1))
    fi
  done < <(ls -1t "$dest"/env-"$hostname_val"-*.env 2>/dev/null || true)
  if [ "$pruned" -gt 0 ]; then
    info "pruned $pruned older backup file(s) past 30-copy retention"
  fi
}

cmd_env() {
  # Effective config + binding snapshot. Strictly non-secret — no
  # passwords, no tokens, no webhook secret values. Use ``audit`` if
  # you need the broker/execution gate detail.
  ensure_dirs
  load_env_host_port
  echo "=== sbctl env ==="
  echo "project    : $PROJECT_ROOT"
  echo "APP_HOST   : $HOST_VALUE"
  echo "APP_PORT   : $PORT_VALUE"
  echo "bind       : $HOST_VALUE:$PORT_VALUE"
  local pid
  pid="$(read_pid)"
  if pid_alive "$pid"; then
    echo "pid        : $pid"
    if [ -r "/proc/$pid/stat" ] && [ -r "/proc/uptime" ]; then
      # /proc/$pid/stat field 22 is start time in clock ticks since
      # boot; combine with /proc/uptime to get a wall-clock age.
      local starttime clk_tck up age h m sec
      starttime="$(awk '{print $22}' "/proc/$pid/stat" 2>/dev/null)"
      clk_tck="$(getconf CLK_TCK 2>/dev/null || echo 100)"
      up="$(awk '{print $1}' /proc/uptime 2>/dev/null)"
      if [ -n "$starttime" ] && [ -n "$up" ] && [ -n "$clk_tck" ]; then
        age="$(awk -v s="$starttime" -v c="$clk_tck" -v u="$up" \
          'BEGIN { v = u - s/c; if (v < 0) v = 0; printf "%d", v }')"
        h=$((age / 3600))
        m=$(((age % 3600) / 60))
        sec=$((age % 60))
        echo "uptime     : ${h}h ${m}m ${sec}s"
      fi
    fi
  else
    echo "pid        : (not running)"
  fi
  if command -v ss >/dev/null 2>&1; then
    local listener_line
    listener_line="$(ss -tlnp "sport = :$PORT_VALUE" 2>/dev/null \
      | awk 'NR>1' | head -n 1 || true)"
    if [ -n "$listener_line" ]; then
      echo "listener   : $listener_line"
    else
      echo "listener   : (none on port $PORT_VALUE)"
    fi
  else
    echo "listener   : (ss not installed)"
  fi
  if command -v tailscale >/dev/null 2>&1; then
    if tailscale funnel status >/dev/null 2>&1; then
      echo "--- tailscale funnel ---"
      tailscale funnel status
    else
      echo "tailscale  : (funnel inactive or not configured)"
    fi
  else
    echo "tailscale  : (tailscale CLI not installed)"
  fi
  local db_path="$PROJECT_ROOT/data/signalbridge.db"
  if [ -f "$db_path" ]; then
    echo "database   : $db_path ($(du -h "$db_path" 2>/dev/null | awk '{print $1}'))"
  else
    echo "database   : $db_path (missing)"
  fi
  if [ -f "$APP_LOG" ]; then
    echo "app log    : $APP_LOG ($(du -h "$APP_LOG" 2>/dev/null | awk '{print $1}'))"
  else
    echo "app log    : $APP_LOG (none yet)"
  fi
  if [ -f "$SERVER_OUT" ]; then
    echo "server out : $SERVER_OUT ($(du -h "$SERVER_OUT" 2>/dev/null | awk '{print $1}'))"
  else
    echo "server out : $SERVER_OUT (none yet)"
  fi
}

usage() {
  cat <<'EOF'
sbctl — SignalBridge control script

Lifecycle:
  sbctl start              start uvicorn in the background
  sbctl stop               stop the running uvicorn
  sbctl restart            stop then start
  sbctl status             show pid / port / health

Observability:
  sbctl logs               tail server.out + signalbridge.log
  sbctl tail [N]           tail signalbridge.log only (default 50 lines)
  sbctl health             curl /health
  sbctl audit              broker/execution gate snapshot
  sbctl env                effective config & runtime info

Execution control:
  sbctl mode <off|test|armed>   set execution mode
  sbctl arm                     shortcut for mode armed
  sbctl disarm                  shortcut for mode off
  sbctl flatten [-y]            emergency flatten-all positions

Testing:
  sbctl test <buy|sell> [symbol] [contracts]   fire one webhook
  sbctl smoke [symbol] [contracts]              buy + flatten round-trip

Maintenance:
  sbctl backup [destination]    backup signalbridge.db and .env

Reads APP_HOST / APP_PORT / ADMIN_USERNAME / ADMIN_PASSWORD / TRADINGVIEW_WEBHOOK_SECRET from .env.
EOF
}

# ----- entrypoint -----

cmd="${1:-}"
[ "$#" -gt 0 ] && shift
case "$cmd" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    cmd_logs ;;
  tail)    cmd_tail "$@" ;;
  health)  cmd_health ;;
  audit)   cmd_audit ;;
  env)     cmd_env ;;
  mode)    cmd_mode "$@" ;;
  arm)     cmd_arm ;;
  disarm)  cmd_disarm ;;
  flatten) cmd_flatten "$@" ;;
  test)    cmd_test "$@" ;;
  smoke)   cmd_smoke "$@" ;;
  backup)  cmd_backup "$@" ;;
  ""|-h|--help|help) usage ;;
  *)
    err "unknown command: $cmd"
    usage
    exit 2
    ;;
esac
