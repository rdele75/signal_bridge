APP_NAME=SignalBridge
APP_HOST=127.0.0.1
APP_PORT=8000

# --- Dashboard authentication ---------------------------------------------
# Required before exposing the dashboard publicly (e.g. via Tailscale Funnel).
# The /webhooks/tradingview endpoint stays open — it has its own
# TRADINGVIEW_WEBHOOK_SECRET shared-secret check below.
#
# Change ADMIN_PASSWORD and SESSION_SECRET to strong random values before
# turning on Funnel. SESSION_SECRET signs the session cookie; rotating it
# logs everyone out.
ADMIN_AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password
# Optional: leave blank. /settings/profile writes a PBKDF2-SHA256 hash
# here once you save a new password from the dashboard — at that point
# ADMIN_PASSWORD above is ignored.
ADMIN_PASSWORD_HASH=
SESSION_SECRET=generate_or_require_secret

# Execution mode: paper (default and safe) | demo | live
# Live is intentionally disabled in this build.
EXECUTION_MODE=paper

# Broker provider — the canonical selector. Choices today:
#   paper      (default, fully functional)
#   topstep    (placeholder — adapter not implemented yet)
BROKER_PROVIDER=paper

# Legacy alias for BROKER_PROVIDER. If BROKER_PROVIDER is unset SignalBridge
# falls back to this value. Same allowed choices.
BROKER=paper

# ===========================================================================
# !!! REQUIRED !!! TradingView webhook shared secret.
#
# SignalBridge REFUSES TO START with the placeholder value below, an empty
# value, or anything shorter than 16 characters. Generate a real secret
# with:
#
#     openssl rand -hex 32
#
# This secret must match the "secret" field in your TradingView alert
# JSON body. Anyone who knows it can submit signed trade signals — never
# share it, commit it, or leave it as the placeholder.
# ===========================================================================
TRADINGVIEW_WEBHOOK_SECRET=REPLACE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Comma-separated list of TradingView tickers you allow this bot to trade.
ALLOWED_SYMBOLS=MNQ1!,MES1!,NQ1!,ES1!

# Risk limits
MAX_CONTRACTS_PER_TRADE=1
# MAX_DAILY_LOSS is measured in futures **points** (not dollars). The
# dashboard's Risk card shows the value as "pts" to match. For MNQ/MES
# at $5/point, MAX_DAILY_LOSS=250 caps the daily loss at $1,250. For
# ES at $50/point that's $12,500. Set this against the contract you
# actually trade.
MAX_DAILY_LOSS=250
MAX_OPEN_POSITIONS=1
ENABLE_LONGS=true
ENABLE_SHORTS=true
ENABLE_KILL_SWITCH=true

# Trading-day boundary used by daily-PnL and "today" counts. UTC is the
# default and matches the storage layout. Set to e.g. America/New_York
# if you want the day rollover to line up with the local trading
# session instead of 00:00 UTC.
TRADING_DAY_TIMEZONE=UTC

# Trade sizing source.
#   STRATEGY_MANAGED_RISK=true   → use the `contracts` field from the
#                                  TradingView alert (the strategy owns
#                                  position size).
#   STRATEGY_MANAGED_RISK=false  → ignore the alert's `contracts` and use
#                                  FIXED_CONTRACTS_PER_TRADE instead.
# MAX_CONTRACTS_PER_TRADE is always enforced as a hard cap in either mode.
STRATEGY_MANAGED_RISK=true
FIXED_CONTRACTS_PER_TRADE=1

# Storage
DATABASE_PATH=data/signalbridge.db
LOG_PATH=logs/signalbridge.log
LOG_LEVEL=INFO

# Reject the same order_id if it arrives again within this many seconds.
DUPLICATE_ORDER_COOLDOWN_SECONDS=300

# Token-bucket rate limit for /webhooks/tradingview. The bucket refills
# at WEBHOOK_RATE_LIMIT_PER_SECOND and holds up to WEBHOOK_RATE_BURST
# tokens. Excess requests return HTTP 429 and are journaled as
# `rate_limited` rejections. Set higher if a legitimate strategy fires
# many alerts per bar; lower to tighten the cap.
WEBHOOK_RATE_LIMIT_PER_SECOND=10
WEBHOOK_RATE_BURST=30

# Reject TradingView alerts unless the chart timeframe is in the allow-list.
# {{interval}} in your alert body provides the timeframe (e.g. "1", "5", "60", "D").
ENABLE_TIMEFRAME_LOCK=false
ALLOWED_TIMEFRAMES=1

# Optional provider-aware symbol mapping file (TradingView -> broker symbol).
# See config/symbols.example.json for the expected shape.
SYMBOLS_MAP_PATH=config/symbols.json

# --- Topstep / TopstepX (ProjectX) ----------------------------------------
# Primary planned futures broker. The adapter is scaffolded: credentials
# persist and the dashboard reflects them (masked), but no real API auth
# or order routing runs yet. See docs/topstep.md for the integration plan.
TOPSTEP_USERNAME=
TOPSTEP_PASSWORD=
TOPSTEP_API_KEY=
TOPSTEP_ACCOUNT_ID=
TOPSTEP_ENV=demo
TOPSTEP_BASE_URL=https://api.topstepx.com
TOPSTEP_WS_URL=https://rtc.topstepx.com
# Auth artifacts written by the adapter; leave empty.
TOPSTEP_TOKEN=
TOPSTEP_TOKEN_EXPIRES_AT=

# --- Topstep order routing safety switches -------------------------------
# Dry-run is the only Topstep order path that is on by default. It builds
# a /api/Order/place payload and journals it, but does NOT submit.
ENABLE_TOPSTEP_ORDER_DRY_RUN=true
# Demo/sim execution is OFF by default. To enable it:
#   1. BROKER_PROVIDER=topstep
#   2. EXECUTION_MODE=demo
#   3. ENABLE_TOPSTEP_ORDER_EXECUTION=true
#   4. TOPSTEP_EXECUTION_CONFIRM=DEMO_ONLY
#   5. ENABLE_LIVE_TRADING must stay false
ENABLE_TOPSTEP_ORDER_EXECUTION=false
TOPSTEP_EXECUTION_CONFIRM=disabled

# --- Live/funded execution gates -----------------------------------------
# Live execution is opt-in and requires the dedicated arm endpoint
# (/api/topstep/live-execution/enable) to flip every gate together.
# Editing these by hand is supported, but the dashboard arm flow is the
# safer path. To enable live execution all of the following must hold:
#   BROKER_PROVIDER=topstep
#   EXECUTION_MODE=live
#   ENABLE_TOPSTEP_ORDER_EXECUTION=true
#   TOPSTEP_EXECUTION_CONFIRM=LIVE_CONFIRMED
#   ENABLE_LIVE_TRADING=true
#   LIVE_TRADING_CONFIRM=I_UNDERSTAND_LIVE_ORDERS
#   LIVE_TRADING_ACCOUNT_ACK=true
ENABLE_LIVE_TRADING=false
LIVE_TRADING_CONFIRM=disabled
LIVE_TRADING_ACCOUNT_ACK=false
# Independent per-trade cap for live submissions. Always enforced in
# addition to MAX_CONTRACTS_PER_TRADE.
LIVE_MAX_CONTRACTS_PER_TRADE=1
# Tickers allowed for live execution. Symbol must appear in this list
# AND have a Topstep contract mapping in config/symbols.json.
LIVE_ALLOWED_SYMBOLS=MES1!,MNQ1!
# Defense in depth — when true, the kill switch must be off before live
# orders are submitted. Leave at true unless you know exactly why.
LIVE_REQUIRE_KILL_SWITCH_OFF=true

# --- Order history + realtime polling -----------------------------------
# Defaults used by /api/broker/order-history. The lookback window is in
# days; the limit caps how many normalized rows come back.
ORDER_HISTORY_LOOKBACK_DAYS=7
ORDER_HISTORY_LIMIT=100
# Realtime account/position/order data. ProjectX exposes a SignalR user
# hub but wiring it requires the `signalrcore` dependency — until then
# polling is the only mode that actually runs.
ENABLE_TOPSTEP_REALTIME=false
TOPSTEP_REALTIME_MODE=polling
TOPSTEP_REALTIME_POLL_SECONDS=5
