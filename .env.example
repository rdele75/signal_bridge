APP_NAME=SignalBridge
APP_HOST=127.0.0.1
APP_PORT=8000

# Execution mode: paper (default and safe) | demo | live
# Live is intentionally disabled in this build.
EXECUTION_MODE=paper

# Broker adapter: paper | tradovate_demo | tradovate_live
BROKER=paper

# Long random shared secret that must match the "secret" field in your
# TradingView alert JSON body. CHANGE THIS before exposing the webhook.
TRADINGVIEW_WEBHOOK_SECRET=change_me_to_a_long_random_secret

# Comma-separated list of TradingView tickers you allow this bot to trade.
ALLOWED_SYMBOLS=MES1!,MNQ1!

# Risk limits
MAX_CONTRACTS_PER_TRADE=1
MAX_DAILY_LOSS=250
MAX_OPEN_POSITIONS=1
ENABLE_LONGS=true
ENABLE_SHORTS=true
ENABLE_KILL_SWITCH=true

# Storage
DATABASE_PATH=data/signalbridge.db
LOG_PATH=logs/signalbridge.log
LOG_LEVEL=INFO

# Broker credentials (only used by non-paper adapters — leave blank for paper)
BROKER_USERNAME=
BROKER_PASSWORD=
BROKER_ACCOUNT_ID=

# Reject the same order_id if it arrives again within this many seconds.
DUPLICATE_ORDER_COOLDOWN_SECONDS=60
